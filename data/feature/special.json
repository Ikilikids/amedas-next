  "74516": {
    "record": "平均気温2位*, 平均最低気温1位* 日照28位",
    "prime": "高知県の足摺岬にある観測所。島嶼部を除くと最も暖かい地点の1つ。",
    "temp": "平均気温は18.4℃(2位*)で島嶼部を除くと鹿児島に次いで高く、伊豆諸島より高い。一方で最高気温は21.4℃と高知よりも1℃ほど低く、穏やかな海洋性気候である。",
    "rain": "降水2563.9mmは高知よりも100mmほど少なく、日照2190.5時間は高知よりも50時間ほど多い。高知と同じく多雨多照で、特に日照は全国28位とかなり長い。",
    "other": "最も似ている気象台は静岡地方気象台だが、かなり明瞭な気候であるため類似度が高い気象台がない。似ているアメダスは潮岬や室戸岬など海洋性気候が明瞭な地点である。"
  },
  "81071": {
    "record": "特になし",
    "prime": "山口県の県庁所在地。日本海に面している。",
    "temp": "平均気温は15.8℃で1.2℃低い。最高気温は下関とほぼ同じ月変化だが、最低気温は2~3℃ほど低く推移する。冬日は9.3日と少なく、松山や宮崎と同程度。",
    "rain": "降水1692.9mmは下関と同程度で、日照1733.2時間は下関より150時間ほど少ない。下関と比べて冬季の日照が短く、梅雨の雨量が少ないが、それでも最多雨月は7月である。",
    "other": "最も似ている気象台は下関地方気象台だが、彦根、松江とも似ている。太平洋側気候ではあるが明瞭ではない。"
  },
  "81286": {
    "record": "特になし",
    "prime": "山口県の県庁所在地。内陸に位置している。",
    "temp": "平均気温は15.6℃で1.4℃低いが、最高気温は21.2℃で下関より1℃高い。猛暑日、真夏日、夏日はいずれも県内1位である。冬日は42.0日で北関東並みに多い。",
    "rain": "降水1927.7mmは下関より200mmほど多く、日照は下関と同程度である。下関と比べて冬季の日照が長く、梅雨の雨量も多い。典型的な西日本太平洋型の気候である。",
    "other": "最も似ている気象台は佐賀地方気象台。下関がかなり顕著な海洋性気候であるため日較差が小さく、あまり似ていない。"
  },
  "82136": {
    "record": "特になし",
    "prime": "福岡県飯塚市にある観測所。内陸に位置している。",
    "temp": "平均気温は16.0℃で福岡より1.3℃低い。福岡よりも冷え込みが強く、冬日は28.4日となっており福岡よりかなり多い。",
    "rain": "降水1813mmは福岡より150mmほど多く、日照1825.9時間は福岡より50時間ほど少ない。月変化はほぼ同じであり、梅雨の降水が多い。",
    "other": "最も似ている気象台は福岡地方気象台。"
  },
  "83137": {
    "record": "猛暑日2位、真夏日1位*、夏日9位*、平均最高気温1位*(5月,6月,7月), 9位*(8月)",
    "prime": "大分県日田市にある観測所。盆地に位置しており夏季の暑さが特徴的。",
    "temp": "平均気温は15.8℃で大分より1℃低い。夏季はかなり暑く、猛暑日22.0日(2位)、真夏日82.2日(1位*)、夏日154.2日(9位*)と上位である。冬の冷え込みも厳しく、冬日は53.2日で大分より40日ほど多く、北関東と同程度である。",
    "rain": "大分と比べると降水は150mmほど多く、日照は200時間ほど少ない。特に梅雨の降水が多く、典型的な九州型の気候である。",
    "other": "最も似ている気象台は熊本地方気象台。気温に関しては熊本をより極端にした気候である。"
  },
